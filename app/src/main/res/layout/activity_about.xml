<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Top Styling Card Frame Header Section -->
    <LinearLayout
        android:id="@+id/aboutHeader"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/header_gradient"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEVELOPER PROFILE"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/aboutHeader"
        android:layout_marginTop="-30dp"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Profile Frame View Component -->
            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                app:cardCornerRadius="60dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/faris_profile"
                    android:scaleType="centerCrop"
                    android:contentDescription="Developer Profile Picture"/>
            </androidx.cardview.widget.CardView>

            <!-- Academic Bio Context Card Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MUHAMMAD FARIS BIN NORAZLAN"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student ID: 2024542795\nCourse: CS240 - Bachelor of Information Technology"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- App User Manual / Instructional Documentation Card Block[cite: 1] -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Application User Manual"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Navigate to the main estimation dashboard calculator.\n2. Pick the targeted billing cycle month via the spinner select tool.\n3. Adjust the responsive slider bar component to choose your kWh consumption metrics (1 to 1000 kWh).\n4. Supply a custom rebate rate value limiting from 0% to 5% max inside the text container.\n5. Select 'Calculate' to verify inputs or 'Save' to save to the offline list.\n6. Select 'History' to pull up recorded entries, change variables, or drop records seamlessly."
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Clickable Interactive Repository Hyperlink Button[cite: 1] -->
            <TextView
                android:id="@+id/tvGithubLink"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🌐 Open Project Source GitHub URL"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/button_style"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2026 Universiti Teknologi MARA (UiTM). All Rights Reserved."
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>