<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Top Fancy Header Banner -->
    <LinearLayout
        android:id="@+id/headerBanner"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/header_gradient"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TNB BILL ESTIMATOR"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculate Electricity Charges &amp; Rebates Instantly"
            android:textColor="#D1C4E9"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerBanner"
        android:layout_marginTop="-20dp"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Instruction Banner Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:backgroundTint="@color/blue_tint"
                android:padding="12dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Instructions: Select month, slide to pick unit usage (1-1000 kWh), set a rebate percentage (0-5%), and press compute."
                    android:textColor="#0288D1"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Main Inputs Card Frame -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Month Spinner Block -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Billing Month"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <Spinner
                    android:id="@+id/spinnerMonth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>

                <!-- Sliders Sector Block -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Electricity Unit Usage"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <SeekBar
                    android:id="@+id/seekBarUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="1000"/>

                <TextView
                    android:id="@+id/tvUnitsVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 kWh"
                    android:textColor="@color/primary_accent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>

                <!-- Rebate Box Input Panel Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rebate Value (0% - 5%)"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/etRebate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="e.g. 5.0"
                    android:background="@android:color/transparent"
                    android:paddingLeft="4dp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- Action Controllers Grid Section -->
            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Calculate"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/button_style"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:backgroundTint="@android:color/holo_blue_bright"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Save Record"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/button_style"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:backgroundTint="@android:color/holo_blue_dark"
                android:layout_marginBottom="20dp"/>

            <!-- Computations Output Status Display Block[cite: 1] -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvOutputTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: RM 0.00"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tvOutputFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final Cost: RM 0.00"
                    android:textSize="20sp"
                    android:textColor="@color/green_success"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- Quick Navigation Shortcuts Footer Segment -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="History"
                    android:textColor="#000000"
                    android:layout_marginRight="4dp"
                    style="@style/Widget.AppCompat.Button.Borderless.Colored"/>

                <Button
                    android:id="@+id/btnAbout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="About Dev"
                    android:textColor="#000000"
                    android:layout_marginLeft="4dp"
                    style="@style/Widget.AppCompat.Button.Borderless.Colored"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>